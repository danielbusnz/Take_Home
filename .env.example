# Required. Both from https://www.browserbase.com (Settings > API Keys, and Project ID).
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Optional. Override the carrier login URLs. Default to the live portals.
# ALLSTATE_LOGIN_URL=
# GEICO_LOGIN_URL=

# Optional dev only. PORT defaults to 3000; the rest tune session reuse and debug logs.
# PORT=3000
# REUSE_TTL_MS=480000
# ALLSTATE_DEBUG=1
